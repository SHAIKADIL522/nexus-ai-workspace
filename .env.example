# OpenAI API key — required for real AI responses
# Without this, enable Recruiter Mode for instant mock responses
OPENAI_API_KEY=sk-your-openai-key-here

# OpenWeatherMap API key — for live weather data
# Free tier available at openweathermap.org
OPENWEATHER_API_KEY=your_openweather_key_here

# Finnhub API key — for live stock data (optional)
# Free tier at finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
